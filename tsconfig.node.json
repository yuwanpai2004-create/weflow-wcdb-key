{
  "compilerOptions": {
    "composite": true,
    "skipLibCheck": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "target": "ES2022",
    "lib": [
      "ES2022"
    ]
  },
  "include": [
    "vite.config.ts",
    "electron/**/*.ts",
    "electron/**/*.d.ts",
    "shared/**/*.json"
  ]
}
